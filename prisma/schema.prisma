generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  password      String
  role          String        @default("artist")
  phone         String?
  commissionPct Float         @default(50)
  avatarUrl     String?
  avatarColor   String        @default("#7c3aed")
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  appointments  Appointment[]
  transactions  Transaction[]
  accounts      Account[]
  sessions      Session[]
  clients       Client[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id           String        @id @default(cuid())
  studioId     String?
  artistId     String?
  name         String
  phone        String?
  email        String?
  birthdate    DateTime?
  notes        String?
  healthNotes  String?
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  artist       User?         @relation(fields: [artistId], references: [id])
}

model Appointment {
  id              String        @id @default(cuid())
  clientId        String?
  artistId        String
  service         String
  value           Float         @default(0)
  deposit         Float         @default(0)
  date            DateTime
  durationMinutes Int           @default(60)
  status          String        @default("pending")
  notes           String?
  style           String?
  paymentMethod   String?
  createdAt       DateTime      @default(now())
  client          Client?       @relation(fields: [clientId], references: [id])
  artist          User          @relation(fields: [artistId], references: [id])
  transactions    Transaction[]
}

model Transaction {
  id            String       @id @default(cuid())
  appointmentId String?
  artistId      String?
  type          String
  category      String?
  description   String
  amount        Float
  paymentMethod String?
  date          DateTime     @default(now())
  createdAt     DateTime     @default(now())
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  artist        User?        @relation(fields: [artistId], references: [id])
}
