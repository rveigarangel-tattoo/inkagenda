generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Studio {
  id            String        @id @default(cuid())
  name          String        @default("Meu Estúdio")
  logo          String?
  commissionPct Float         @default(50)
  plan          String        @default("free")
  createdAt     DateTime      @default(now())
  users         User[]
  clients       Client[]
  appointments  Appointment[]
  transactions  Transaction[]
  invites       Invite[]
  settlements   Settlement[]
}

model Invite {
  id            String    @id @default(cuid())
  studioId      String
  name          String
  email         String?
  phone         String?
  role          String    @default("artist")
  isArtist      Boolean   @default(false)
  commissionPct Float     @default(50)
  avatarColor   String    @default("#7c3aed")
  token         String    @unique @default(cuid())
  usedAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  studio        Studio    @relation(fields: [studioId], references: [id])
}

model User {
  id                   String       @id @default(cuid())
  studioId             String
  name                 String
  email                String       @unique
  username             String?      @unique
  password             String
  role                 String       @default("artist")
  isArtist             Boolean      @default(false)
  phone                String?
  commissionPct        Float        @default(50)
  avatarUrl            String?
  avatarColor          String       @default("#7c3aed")
  isActive             Boolean      @default(true)
  settlementFrequency  String       @default("monthly")
  settlementDays       Int          @default(30)
  settlementCycleStart DateTime?
  createdAt            DateTime     @default(now())
  studio               Studio       @relation(fields: [studioId], references: [id])
  appointments         Appointment[]
  transactions         Transaction[]
  accounts             Account[]
  sessions             Session[]
  clients              Client[]
  settlements          Settlement[] @relation("SettlementArtist")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id           String        @id @default(cuid())
  studioId     String
  artistId     String?
  name         String
  phone        String?
  email        String?
  birthdate    DateTime?
  notes        String?
  healthNotes  String?
  createdAt    DateTime      @default(now())
  studio       Studio        @relation(fields: [studioId], references: [id])
  artist       User?         @relation(fields: [artistId], references: [id], onDelete: SetNull)
  appointments Appointment[]
}

model Appointment {
  id              String           @id @default(cuid())
  studioId        String
  clientId        String?
  artistId        String?
  service         String
  value           Float            @default(0)
  deposit         Float            @default(0)
  date            DateTime
  durationMinutes Int              @default(60)
  status          String           @default("pending")
  notes           String?
  style           String?
  paymentMethod   String?
  createdAt       DateTime         @default(now())
  studio          Studio           @relation(fields: [studioId], references: [id])
  client          Client?          @relation(fields: [clientId], references: [id])
  artist          User?            @relation(fields: [artistId], references: [id], onDelete: SetNull)
  transactions    Transaction[]
  settlementItems SettlementItem[]
}

model Transaction {
  id            String       @id @default(cuid())
  studioId      String
  appointmentId String?
  artistId      String?
  type          String
  category      String?
  description   String
  amount        Float
  paymentMethod String?
  date          DateTime     @default(now())
  createdAt     DateTime     @default(now())
  studio        Studio       @relation(fields: [studioId], references: [id])
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  artist        User?        @relation(fields: [artistId], references: [id], onDelete: SetNull)
}

model Settlement {
  id            String           @id @default(cuid())
  studioId      String
  artistId      String
  periodStart   DateTime
  periodEnd     DateTime
  totalGross    Float            @default(0)
  artistAmount  Float            @default(0)
  studioAmount  Float            @default(0)
  commissionPct Float            @default(50)
  pixAmount     Float            @default(0)
  cashAmount    Float            @default(0)
  cardAmount    Float            @default(0)
  otherAmount   Float            @default(0)
  status           String           @default("closed")
  notes            String?
  adjustmentAmount Float            @default(0)
  adjustmentNote   String?
  paidAt           DateTime?
  createdAt     DateTime         @default(now())
  studio        Studio           @relation(fields: [studioId], references: [id])
  artist        User             @relation("SettlementArtist", fields: [artistId], references: [id])
  items         SettlementItem[]
}

model SettlementItem {
  id            String       @id @default(cuid())
  settlementId  String
  appointmentId String?
  clientName    String?
  service       String
  serviceDate   DateTime
  value         Float
  paymentMethod String?
  artistAmount  Float
  studioAmount  Float
  settlement    Settlement   @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
}
